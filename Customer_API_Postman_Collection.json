{
	"info": {
		"_postman_id": "customer-api-collection",
		"name": "Customer API - JWT Authentication",
		"description": "Complete API collection for Customer management with JWT authentication",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"auth": {
		"type": "bearer",
		"bearer": [
			{
				"key": "token",
				"value": "{{jwt_token}}",
				"type": "string"
			}
		]
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000",
			"type": "string"
		},
		{
			"key": "jwt_token",
			"value": "",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Authentication",
			"item": [
				{
					"name": "Login - Get JWT Token",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"jwt_token\", jsonData.token);",
									"    pm.collectionVariables.set(\"jwt_token\", jsonData.token);",
									"    console.log(\"JWT Token saved: \" + jsonData.token);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"username\": \"admin@example.com\",\n    \"password\": \"password\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/login",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"login"
							]
						},
						"description": "Login with email and password to get JWT token. The token will be automatically saved to the collection variable."
					},
					"response": []
				}
			]
		},
		{
			"name": "Customers",
			"item": [
				{
					"name": "Get All Customers",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/customers",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"customers"
							]
						},
						"description": "Retrieve all customers from the database."
					},
					"response": []
				},
				{
					"name": "Get Customer by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/customers/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"customers",
								"1"
							]
						},
						"description": "Get a single customer by ID. Change the ID in the URL."
					},
					"response": []
				},
				{
					"name": "Create Customer",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"email\": \"john.doe@example.com\",\n    \"phoneNumber\": \"+1234567890\",\n    \"address\": \"123 Main Street\",\n    \"city\": \"New York\",\n    \"postalCode\": \"10001\",\n    \"country\": \"USA\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/customers",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"customers"
							]
						},
						"description": "Create a new customer. All fields except phoneNumber, address, city, postalCode, and country are required."
					},
					"response": []
				},
				{
					"name": "Update Customer (Full)",
					"request": {
						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"firstName\": \"Jane\",\n    \"lastName\": \"Smith\",\n    \"email\": \"jane.smith@example.com\",\n    \"phoneNumber\": \"+1987654321\",\n    \"address\": \"456 Oak Avenue\",\n    \"city\": \"Los Angeles\",\n    \"postalCode\": \"90001\",\n    \"country\": \"USA\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/customers/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"customers",
								"1"
							]
						},
						"description": "Update all fields of a customer. Change the ID in the URL."
					},
					"response": []
				},
				{
					"name": "Update Customer (Partial)",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"phoneNumber\": \"+1111111111\",\n    \"city\": \"San Francisco\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/customers/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"customers",
								"1"
							]
						},
						"description": "Partially update a customer. Only send the fields you want to update."
					},
					"response": []
				},
				{
					"name": "Delete Customer",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/api/customers/1",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"customers",
								"1"
							]
						},
						"description": "Delete a customer by ID. Change the ID in the URL."
					},
					"response": []
				}
			]
		}
	]
}
