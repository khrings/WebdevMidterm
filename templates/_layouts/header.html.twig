<header class="flex items-center justify-between px-6 py-4 bg-white border-b-4 border-indigo-600">
    <div class="flex items-center">
        <button @click="sidebarOpen = true" class="text-gray-500 focus:outline-none lg:hidden">
            <svg class="w-6 h-6" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M4 6H20M4 12H20M4 18H11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
        </button>

        <div class="relative mx-4 lg:mx-0" x-data="{ searchQuery: '', searchResults: [], showResults: false }">
            <span class="absolute inset-y-0 left-0 flex items-center pl-3">
                <svg class="w-5 h-5 text-gray-500" viewBox="0 0 24 24" fill="none">
                    <path d="M21 21L15 15M17 10C17 13.866 13.866 17 10 17C6.13401 17 3 13.866 3 10C3 6.13401 6.13401 3 10 3C13.866 3 17 6.13401 17 10Z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
            </span>

            <form action="{{ path('app_search') }}" method="GET" class="relative">
                <input 
                    x-model="searchQuery"
                    @input="showResults = searchQuery.length > 2"
                    @keydown.escape="showResults = false"
                    class="w-32 pl-10 pr-4 py-2 border border-gray-300 rounded-md form-input sm:w-64 focus:border-indigo-600 focus:ring focus:ring-indigo-200 focus:ring-opacity-50" 
                    type="text" 
                    name="q"
                    placeholder="Search everything..."
                    autocomplete="off">
                
                <!-- Search Results Dropdown -->
                <div 
                    x-show="showResults && searchQuery.length > 2"
                    @click.away="showResults = false"
                    x-cloak
                    class="absolute z-50 w-full mt-2 bg-white rounded-lg shadow-xl border border-gray-200 max-h-96 overflow-y-auto">
                    <div class="p-3 text-sm text-gray-500 border-b bg-gradient-to-r from-indigo-50 to-purple-50">
                        <span class="font-semibold text-indigo-600">Quick Search:</span> Pet Profiles, Pet Owners, Products, Orders, Stocks
                    </div>
                    <a href="{{ path('app_pet_profile_management_index') }}?search=" :href="'{{ path('app_pet_profile_management_index') }}?search=' + searchQuery" class="block px-4 py-3 hover:bg-indigo-50 border-b transition-colors">
                        <div class="flex items-center">
                            <div class="p-2 bg-cyan-100 rounded-lg mr-3">
                                <svg class="w-4 h-4 text-cyan-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">Pet Profiles</span>
                                <p class="text-xs text-gray-500">Search by pet name, breed, species</p>
                            </div>
                        </div>
                    </a>
                    <a href="{{ path('app_pet_owners_index') }}?search=" :href="'{{ path('app_pet_owners_index') }}?search=' + searchQuery" class="block px-4 py-3 hover:bg-indigo-50 border-b transition-colors">
                        <div class="flex items-center">
                            <div class="p-2 bg-teal-100 rounded-lg mr-3">
                                <svg class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">Pet Owners</span>
                                <p class="text-xs text-gray-500">Search by owner name, contact, email</p>
                            </div>
                        </div>
                    </a>
                    <a href="{{ path('app_productss_index') }}?search=" :href="'{{ path('app_productss_index') }}?search=' + searchQuery" class="block px-4 py-3 hover:bg-indigo-50 border-b transition-colors">
                        <div class="flex items-center">
                            <div class="p-2 bg-pink-100 rounded-lg mr-3">
                                <svg class="w-4 h-4 text-pink-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                </svg>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">Products</span>
                                <p class="text-xs text-gray-500">Search by name, description, category</p>
                            </div>
                        </div>
                    </a>
                    <a href="{{ path('app_orders_index') }}?search=" :href="'{{ path('app_orders_index') }}?search=' + searchQuery" class="block px-4 py-3 hover:bg-indigo-50 border-b transition-colors">
                        <div class="flex items-center">
                            <div class="p-2 bg-orange-100 rounded-lg mr-3">
                                <svg class="w-4 h-4 text-orange-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                                </svg>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">Orders</span>
                                <p class="text-xs text-gray-500">Search by order code, customer, status</p>
                            </div>
                        </div>
                    </a>
                    <a href="{{ path('app_stocks_index') }}?search=" :href="'{{ path('app_stocks_index') }}?search=' + searchQuery" class="block px-4 py-3 hover:bg-indigo-50 border-b transition-colors">
                        <div class="flex items-center">
                            <div class="p-2 bg-green-100 rounded-lg mr-3">
                                <svg class="w-4 h-4 text-green-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">Stocks</span>
                                <p class="text-xs text-gray-500">Search by batch number, supplier</p>
                            </div>
                        </div>
                    </a>
                    <a href="{{ path('app_category_index') }}?search=" :href="'{{ path('app_category_index') }}?search=' + searchQuery" class="block px-4 py-3 hover:bg-indigo-50 border-b transition-colors">
                        <div class="flex items-center">
                            <div class="p-2 bg-blue-100 rounded-lg mr-3">
                                <svg class="w-4 h-4 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                            </div>
                            <div>
                                <span class="text-sm font-semibold text-gray-800">Categories</span>
                                <p class="text-xs text-gray-500">Search product categories</p>
                            </div>
                        </div>
                    </a>
                    <button type="submit" class="block w-full px-4 py-3 text-left hover:bg-gradient-to-r hover:from-indigo-500 hover:to-purple-500 hover:text-white text-indigo-600 font-semibold transition-all">
                        <div class="flex items-center">
                            <svg class="w-5 h-5 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                            <span>Search all for "<span x-text="searchQuery" class="font-bold"></span>"</span>
                        </div>
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    {# <div class="flex items-center">
        <div x-data="{ dropdownOpen: false }"  class="relative">
            <button @click="dropdownOpen = ! dropdownOpen" class="relative block w-8 h-8 overflow-hidden rounded-full shadow focus:outline-none">
                <img class="object-cover w-full h-full" src="https://images.unsplash.com/photo-1528892952291-009c663ce843?ixlib=rb-1.2.1&ixid=eyJhcHBfaWQiOjEyMDd9&auto=format&fit=crop&w=296&q=80" alt="Your avatar">
            </button>

            <div x-cloak x-show="dropdownOpen" @click="dropdownOpen = false" class="fixed inset-0 z-10 w-full h-full"></div>
        </div>
    </div> #}
</header>