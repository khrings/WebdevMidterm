{% extends '_layouts/master.html.twig' %}

{% block title %}Admin Dashboard{% endblock %}

{% block body %}

<!-- Header Section -->
<div class="mb-8">
    <h1 class="text-4xl font-bold text-gray-800 mb-2">Admin Dashboard</h1>
    <p class="text-gray-600">Complete system overview and user management statistics</p>
</div>

<!-- Stats Cards Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
    <!-- Total Users -->
    <div class="relative overflow-hidden bg-gradient-to-br from-blue-500 via-blue-600 to-indigo-700 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="absolute top-0 right-0 w-32 h-32 transform translate-x-8 -translate-y-8">
            <div class="absolute inset-0 bg-white opacity-10 rounded-full"></div>
        </div>
        <div class="relative p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-white bg-opacity-20 rounded-xl backdrop-blur-sm">
                    <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </div>
                <div class="text-right">
                    <p class="text-white text-opacity-90 text-sm font-medium mb-1">Total Users</p>
                    <h2 class="text-5xl font-bold text-white">{{ totalUsers }}</h2>
                </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white border-opacity-20">
                <p class="text-white text-opacity-80 text-sm">All registered users</p>
            </div>
        </div>
    </div>

    <!-- Admins -->
    <div class="relative overflow-hidden bg-gradient-to-br from-red-500 via-red-600 to-rose-700 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="absolute top-0 right-0 w-32 h-32 transform translate-x-8 -translate-y-8">
            <div class="absolute inset-0 bg-white opacity-10 rounded-full"></div>
        </div>
        <div class="relative p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-white bg-opacity-20 rounded-xl backdrop-blur-sm">
                    <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                    </svg>
                </div>
                <div class="text-right">
                    <p class="text-white text-opacity-90 text-sm font-medium mb-1">Administrators</p>
                    <h2 class="text-5xl font-bold text-white">{{ totalAdmins }}</h2>
                </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white border-opacity-20">
                <p class="text-white text-opacity-80 text-sm">System administrators</p>
            </div>
        </div>
    </div>

    <!-- Staff -->
    <div class="relative overflow-hidden bg-gradient-to-br from-green-500 via-green-600 to-emerald-700 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="absolute top-0 right-0 w-32 h-32 transform translate-x-8 -translate-y-8">
            <div class="absolute inset-0 bg-white opacity-10 rounded-full"></div>
        </div>
        <div class="relative p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-white bg-opacity-20 rounded-xl backdrop-blur-sm">
                    <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
                    </svg>
                </div>
                <div class="text-right">
                    <p class="text-white text-opacity-90 text-sm font-medium mb-1">Staff Members</p>
                    <h2 class="text-5xl font-bold text-white">{{ totalStaff }}</h2>
                </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white border-opacity-20">
                <p class="text-white text-opacity-80 text-sm">Active staff users</p>
            </div>
        </div>
    </div>

    <!-- Products -->
    <div class="relative overflow-hidden bg-gradient-to-br from-purple-500 via-purple-600 to-violet-700 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="absolute top-0 right-0 w-32 h-32 transform translate-x-8 -translate-y-8">
            <div class="absolute inset-0 bg-white opacity-10 rounded-full"></div>
        </div>
        <div class="relative p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-white bg-opacity-20 rounded-xl backdrop-blur-sm">
                    <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14H7v-5h5v5zm7 0h-5v-5h5v5zm0-7h-5V7h5v3z"/>
                    </svg>
                </div>
                <div class="text-right">
                    <p class="text-white text-opacity-90 text-sm font-medium mb-1">Products</p>
                    <h2 class="text-5xl font-bold text-white">{{ totalProducts }}</h2>
                </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white border-opacity-20">
                <p class="text-white text-opacity-80 text-sm">Total products catalog</p>
            </div>
        </div>
    </div>

    <!-- Orders -->
    <div class="relative overflow-hidden bg-gradient-to-br from-orange-500 via-orange-600 to-amber-700 rounded-xl shadow-lg hover:shadow-2xl transition-all duration-300 transform hover:-translate-y-1">
        <div class="absolute top-0 right-0 w-32 h-32 transform translate-x-8 -translate-y-8">
            <div class="absolute inset-0 bg-white opacity-10 rounded-full"></div>
        </div>
        <div class="relative p-6">
            <div class="flex items-center justify-between mb-4">
                <div class="p-3 bg-white bg-opacity-20 rounded-xl backdrop-blur-sm">
                    <svg class="w-10 h-10 text-white" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z"/>
                    </svg>
                </div>
                <div class="text-right">
                    <p class="text-white text-opacity-90 text-sm font-medium mb-1">Orders</p>
                    <h2 class="text-5xl font-bold text-white">{{ totalOrders }}</h2>
                </div>
            </div>
            <div class="mt-4 pt-4 border-t border-white border-opacity-20">
                <p class="text-white text-opacity-80 text-sm">All time orders</p>
            </div>
        </div>
    </div>
</div>

<!-- Pet of the Month Section -->
{% if petOfTheMonth %}
<div class="mb-8">
    <div class="bg-gradient-to-br from-amber-400 via-orange-400 to-yellow-500 rounded-xl shadow-2xl overflow-hidden">
        <div class="p-6">
            <div class="flex items-center gap-3 mb-4">
                <span class="text-4xl">⭐</span>
                <div>
                    <h2 class="text-3xl font-bold text-white drop-shadow-lg">Pet of the Month</h2>
                    <p class="text-white text-opacity-90 text-sm">Featured this month</p>
                </div>
            </div>
            
            <div class="bg-white rounded-lg p-6 shadow-lg">
                <div class="flex flex-col md:flex-row gap-6 items-center">
                    <!-- Pet Image -->
                    <div class="flex-shrink-0">
                        {% if petOfTheMonth.image %}
                            <img src="{{ asset('uploads/pets/' ~ petOfTheMonth.image) }}" 
                                 alt="{{ petOfTheMonth.name }}" 
                                 class="w-48 h-48 rounded-full object-cover border-4 border-amber-400 shadow-xl">
                        {% else %}
                            <div class="w-48 h-48 rounded-full bg-gradient-to-br from-amber-100 to-orange-200 flex items-center justify-center border-4 border-amber-400 shadow-xl">
                                <span class="text-7xl">🐾</span>
                            </div>
                        {% endif %}
                    </div>
                    
                    <!-- Pet Details -->
                    <div class="flex-1 text-center md:text-left">
                        <h3 class="text-4xl font-bold text-gray-800 mb-2">{{ petOfTheMonth.name }}</h3>
                        <div class="space-y-2 mb-4">
                            <p class="text-lg text-gray-600">
                                <span class="font-semibold">Owner:</span> 
                                {{ petOfTheMonth.owner ? petOfTheMonth.owner.fullName : 'No Owner' }}
                            </p>
                            <p class="text-lg text-gray-600">
                                <span class="font-semibold">Species:</span> {{ petOfTheMonth.species }}
                            </p>
                            <p class="text-lg text-gray-600">
                                <span class="font-semibold">Breed:</span> {{ petOfTheMonth.breed }}
                            </p>
                            <p class="text-lg text-gray-600">
                                <span class="font-semibold">Age:</span> {{ petOfTheMonth.age }} years old
                            </p>
                        </div>
                        <a href="{{ path('app_pet_profile_management_show', {'id': petOfTheMonth.id}) }}" 
                           class="inline-flex items-center gap-2 bg-gradient-to-r from-amber-500 to-orange-500 text-white px-6 py-3 rounded-lg font-semibold hover:from-amber-600 hover:to-orange-600 transition-all shadow-lg hover:shadow-xl">
                            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                            </svg>
                            View Full Profile
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endif %}

<!-- Recent Users Section -->
<div class="bg-white rounded-xl shadow-lg overflow-hidden">
    <div class="bg-gradient-to-r from-gray-50 to-gray-100 px-6 py-4 border-b border-gray-200">
        <h2 class="text-2xl font-bold text-gray-800">Recent Users</h2>
        <p class="text-sm text-gray-600 mt-1">Latest registered users in the system</p>
    </div>
    <div class="overflow-x-auto">
        <table class="w-full">
            <thead class="bg-gray-50 border-b border-gray-200">
                <tr>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Name</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Email</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Role</th>
                    <th class="px-6 py-4 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Created</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-200">
                {% for user in recentUsers %}
                <tr class="hover:bg-gray-50 transition-colors">
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm font-medium text-gray-900">{{ user.fullName }}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        <div class="text-sm text-gray-600">{{ user.email }}</div>
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap">
                        {% if user.isAdmin() %}
                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-red-100 text-red-800">
                                Admin
                            </span>
                        {% elseif user.isStaff() %}
                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-blue-100 text-blue-800">
                                Staff
                            </span>
                        {% else %}
                            <span class="px-3 py-1 inline-flex text-xs leading-5 font-semibold rounded-full bg-gray-100 text-gray-800">
                                User
                            </span>
                        {% endif %}
                    </td>
                    <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-600">
                        {{ user.createdAt ? user.createdAt|date('M d, Y') : '' }}
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="4" class="px-6 py-8 text-center text-gray-500">
                        <svg class="mx-auto h-12 w-12 text-gray-400 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                        <p class="text-sm font-medium">No users found</p>
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
    <div class="bg-gray-50 px-6 py-4 border-t border-gray-200">
        <a href="{{ path('app_user_management_index') }}" class="inline-flex items-center text-sm font-medium text-blue-600 hover:text-blue-800 transition-colors">
            View all users 
            <svg class="ml-2 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
        </a>
    </div>
</div>

{% endblock %}
