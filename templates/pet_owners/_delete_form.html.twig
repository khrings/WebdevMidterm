<form method="post" action="{{ path('app_pet_owners_delete', {'id': pet_owner.id}) }}" onsubmit="return confirm('Are you sure you want to delete this pet owner?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ pet_owner.id) }}">
    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-2 rounded-lg transition duration-200">
        Delete Pet Owner
    </button>
</form>
