{% extends '_layouts/master.html.twig' %}

{% block title %}Change Password{% endblock %}

{% block body %}
<div class="container mx-auto px-6 py-8">
    <div class="max-w-3xl mx-auto">
        <!-- Flash Messages -->
        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="mb-4 p-4 rounded-lg {% if label == 'success' %}bg-green-100 text-green-800{% elseif label == 'error' %}bg-red-100 text-red-800{% else %}bg-blue-100 text-blue-800{% endif %}">
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Change Password</h1>
            <p class="text-gray-600 mt-2">Update your password to keep your account secure</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
            <form method="post" class="space-y-6">
                <input type="hidden" name="_token" value="{{ csrf_token('change_password') }}">

                <div>
                    <label for="currentPassword" class="block text-sm font-medium text-gray-700 mb-2">Current Password</label>
                    <input type="password" 
                           id="currentPassword" 
                           name="currentPassword" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           required
                           placeholder="Enter your current password">
                </div>

                <div>
                    <label for="newPassword" class="block text-sm font-medium text-gray-700 mb-2">New Password</label>
                    <input type="password" 
                           id="newPassword" 
                           name="newPassword" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           required
                           minlength="6"
                           placeholder="Enter your new password (min. 6 characters)">
                    <p class="text-sm text-gray-500 mt-1">Password must be at least 6 characters long</p>
                </div>

                <div>
                    <label for="confirmPassword" class="block text-sm font-medium text-gray-700 mb-2">Confirm New Password</label>
                    <input type="password" 
                           id="confirmPassword" 
                           name="confirmPassword" 
                           class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent"
                           required
                           minlength="6"
                           placeholder="Confirm your new password">
                </div>

                <div class="flex gap-3 pt-4">
                    <button type="submit" class="bg-blue-600 hover:bg-blue-700 text-white font-semibold px-6 py-3 rounded-lg transition duration-200">
                        Change Password
                    </button>
                    <a href="{{ path('app_profile') }}" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold px-6 py-3 rounded-lg transition duration-200">
                        Cancel
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
{% endblock %}
