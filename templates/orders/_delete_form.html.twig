<form method="post" action="{{ path('app_orders_delete', {'id': order.id}) }}" onsubmit="return confirm('Are you sure you want to delete this order?');">
    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
    <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold px-6 py-2 rounded-lg transition duration-200">
        Delete Order
    </button>
</form>
