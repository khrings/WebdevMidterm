{% extends '_layouts/master.html.twig' %}

{% block title %}Order Details{% endblock %}

{% block body %}
<div class="container mx-auto px-6 py-8">
    <div class="max-w-3xl mx-auto">
        <div class="mb-6">
            <h1 class="text-3xl font-bold text-gray-800">Order Details</h1>
            <p class="text-gray-600 mt-2">View order information</p>
        </div>

        <div class="bg-white rounded-lg shadow-lg p-6">
            <table class="w-full">
                <tbody class="divide-y divide-gray-200">
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Order Number</th>
                        <td class="px-4 py-3 text-gray-900">{{ order.orderNumber }}</td>
                    </tr>
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Product</th>
                        <td class="px-4 py-3 text-gray-900">
                            {% if order.product %}
                                {{ order.product.name }}
                                <span class="text-gray-500 text-sm">(₱{{ order.product.price|number_format(2, '.', ',') }})</span>
                            {% else %}
                                <span class="text-gray-400 italic">No product selected</span>
                            {% endif %}
                        </td>
                    </tr>
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Customer Name</th>
                        <td class="px-4 py-3 text-gray-900">{{ order.customerName }}</td>
                    </tr>
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Customer Email</th>
                        <td class="px-4 py-3 text-gray-900">{{ order.customerEmail ?? '-' }}</td>
                    </tr>
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Order Date</th>
                        <td class="px-4 py-3 text-gray-900">{{ order.orderDate|date('F d, Y H:i:s') }}</td>
                    </tr>
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Total Amount</th>
                        <td class="px-4 py-3 text-gray-900 font-semibold">₱{{ order.totalAmount|number_format(2, '.', ',') }}</td>
                    </tr>
                    <tr>
                        <th class="px-4 py-3 text-left text-gray-600 font-semibold">Status</th>
                        <td class="px-4 py-3">
                            {% if order.status == 'Completed' %}
                                <span class="px-3 py-1 rounded-full text-sm font-semibold bg-green-100 text-green-800">{{ order.status }}</span>
                            {% elseif order.status == 'Processing' %}
                                <span class="px-3 py-1 rounded-full text-sm font-semibold bg-blue-100 text-blue-800">{{ order.status }}</span>
                            {% elseif order.status == 'Pending' %}
                                <span class="px-3 py-1 rounded-full text-sm font-semibold bg-yellow-100 text-yellow-800">{{ order.status }}</span>
                            {% else %}
                                <span class="px-3 py-1 rounded-full text-sm font-semibold bg-red-100 text-red-800">{{ order.status }}</span>
                            {% endif %}
                        </td>
                    </tr>
                </tbody>
            </table>

            <div class="flex gap-3 mt-6 pt-6 border-t border-gray-200">
                <a href="{{ path('app_orders_index') }}" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold px-6 py-2 rounded-lg transition duration-200">
                    Back to List
                </a>
                {% if order.status != 'Completed' %}
                <a href="{{ path('app_orders_edit', {'id': order.id}) }}" class="bg-yellow-500 hover:bg-yellow-600 text-white font-semibold px-6 py-2 rounded-lg transition duration-200">
                    Edit
                </a>
                {% endif %}
                {{ include('orders/_delete_form.html.twig') }}
            </div>
        </div>
    </div>
</div>
{% endblock %}
