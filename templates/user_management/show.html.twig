{% extends '_layouts/master.html.twig' %}

{% block title %}{{ user.fullName }} - Details{% endblock %}

{% block body %}
<div style="padding: 20px;">
    <div class="container mx-auto px-1 py-1" style="font-family: 'Franklin Gothic Medium', 'Arial Narrow', Arial, sans-serif;">

        <!-- Header -->
        <div class="flex justify-between items-center mb-6">
            <div>
                <h1 class="text-3xl font-bold text-gray-800">User Details</h1>
                <p class="text-gray-600 mt-1">View user information and account details</p>
            </div>
            <a href="{{ path('app_user_management_index') }}" 
               style="display: inline-flex; align-items: center; gap: 8px; background: #10b981; color: white; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-size: 14px; font-weight: 600; transition: background 0.2s;">
                <svg style="width: 16px; height: 16px;" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"/>
                </svg>
                Back to list
            </a>
        </div>

        <!-- User Details Card -->
        <div style="display: flex; justify-content: center; margin-bottom: 40px;">
            <div style="background: white; border-radius: 16px; box-shadow: 0 4px 10px rgba(0,0,0,0.08); width: 100%; max-width: 400px; overflow: hidden;">
                
                <!-- Header Section -->
                <div style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); padding: 20px; color: white; text-align: center;">
                    <div style="width: 70px; height: 70px; background: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; font-size: 28px; font-weight: bold; color: #667eea; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">
                        {{ user.fullName|slice(0, 1)|upper }}
                    </div>
                    <h2 style="font-size: 20px; font-weight: 700; margin: 0;">{{ user.fullName }}</h2>
                    <p style="font-size: 13px; margin-top: 6px; opacity: 0.9;">User Account Information</p>
                </div>

                <!-- Details Content -->
                <div style="padding: 24px;">
                    
                    <!-- Full Name -->
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            Full Name
                        </label>
                        <div style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #f9fafb; color: #374151;">
                            {{ user.fullName }}
                        </div>
                    </div>

                    <!-- Email -->
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            Email Address
                        </label>
                        <div style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #f9fafb; color: #374151;">
                            {{ user.email }}
                        </div>
                    </div>

                    <!-- Role -->
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            User Role
                        </label>
                        <div style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #f9fafb;">
                            {% if user.isAdmin %}
                                <span style="color: #ef4444; font-weight: 600;">Administrator</span>
                            {% elseif user.isStaff %}
                                <span style="color: #3b82f6; font-weight: 600;">Staff</span>
                            {% else %}
                                <span style="color: #10b981; font-weight: 600;">User</span>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Status -->
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            Account Status
                        </label>
                        <div style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #f9fafb;">
                            {% if user.status == 'active' %}
                                <span style="color: #10b981; font-weight: 600;">Active</span>
                            {% elseif user.status == 'disabled' %}
                                <span style="color: #ef4444; font-weight: 600;">Disabled</span>
                            {% else %}
                                <span style="color: #6b7280; font-weight: 600;">{{ user.status|default('Unknown') }}</span>
                            {% endif %}
                        </div>
                    </div>

                    <!-- Member Since -->
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            Member Since
                        </label>
                        <div style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #f9fafb; color: #374151;">
                            {{ user.createdAt ? user.createdAt|date('F d, Y') : 'N/A' }}
                        </div>
                    </div>

                    <!-- User ID -->
                    <div style="margin-bottom: 20px;">
                        <label style="display: block; font-size: 12px; font-weight: 600; color: #374151; margin-bottom: 6px;">
                            User ID
                        </label>
                        <div style="width: 100%; padding: 10px 12px; border: 1px solid #d1d5db; border-radius: 6px; font-size: 13px; background: #f9fafb; color: #6b7280; font-family: monospace;">
                            #{{ user.id }}
                        </div>
                    </div>

                    <!-- Divider -->
                    <div style="border-top: 1px solid #e5e7eb; margin: 20px 0;"></div>

                    <!-- Action Buttons -->
                    <div style="display: flex; gap: 10px; justify-content: flex-end;">
                        <form method="post" action="{{ path('app_user_management_delete', {'id': user.id}) }}"
                              onsubmit="return confirm('Are you sure you want to delete this user?');"
                              style="margin: 0;">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                            <button type="submit"
                                    style="padding: 10px 20px; background: #ef4444; color: white; border: none; border-radius: 6px; font-size: 13px; font-weight: 600; cursor: pointer; transition: background 0.2s;">
                                Delete User
                            </button>
                        </form>
                        <a href="{{ path('app_user_management_edit', {'id': user.id}) }}"
                           style="padding: 10px 20px; background: #3b82f6; color: white; border-radius: 6px; text-decoration: none; font-size: 13px; font-weight: 600; transition: background 0.2s;">
                            Edit User
                        </a>
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>
{% endblock %}
