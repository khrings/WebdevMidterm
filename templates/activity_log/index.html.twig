{% extends '_layouts/master.html.twig' %}

{% block title %}Activity Logs{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/jquery.dataTables.min.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/1.13.7/css/dataTables.tailwindcss.min.css">
{% endblock %}

{% block body %}
<h3 class="text-gray-700 text-3xl font-medium mb-6">Activity Logs</h3>
<p class="text-sm text-gray-600 mb-6">View all system activity logs (read-only)</p>

<!-- Filter Form -->
            <form method="GET" action="{{ path('app_activity_log') }}" class="mb-6 bg-gray-50 p-4 rounded-lg">
                <div class="grid grid-cols-1 md:grid-cols-4 gap-4">
                    <div>
                        <label for="username" class="block text-sm font-medium text-gray-700 mb-1">Username</label>
                        <select name="username" id="username" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">All Users</option>
                            {% for user in usernames %}
                                <option value="{{ user }}" {% if filters.username == user %}selected{% endif %}>{{ user }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label for="action" class="block text-sm font-medium text-gray-700 mb-1">Action</label>
                        <select name="action" id="action" class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                            <option value="">All Actions</option>
                            {% for act in actions %}
                                <option value="{{ act }}" {% if filters.action == act %}selected{% endif %}>{{ act }}</option>
                            {% endfor %}
                        </select>
                    </div>

                    <div>
                        <label for="date_from" class="block text-sm font-medium text-gray-700 mb-1">From Date</label>
                        <input type="date" name="date_from" id="date_from" value="{{ filters.date_from }}" 
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>

                    <div>
                        <label for="date_to" class="block text-sm font-medium text-gray-700 mb-1">To Date</label>
                        <input type="date" name="date_to" id="date_to" value="{{ filters.date_to }}" 
                               class="w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>

                <div class="mt-4 flex gap-2">
                    <button type="submit" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        Apply Filters
                    </button>
                    <a href="{{ path('app_activity_log') }}" class="px-4 py-2 bg-gray-300 text-gray-700 rounded-md hover:bg-gray-400 focus:outline-none focus:ring-2 focus:ring-gray-500">
                        Clear Filters
                    </a>
                </div>
            </form>

            <!-- Activity Logs Table -->
            <div class="overflow-x-auto">
                <table id="activityLogsTable" class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">ID</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Username</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Role</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Action</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Target Data</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Timestamp</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        {% for log in logs %}
                        <tr class="hover:bg-gray-50">
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ log.id }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">{{ log.username }}</td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full
                                    {% if log.role == 'ROLE_ADMIN' %}
                                        bg-red-100 text-red-800
                                    {% elseif log.role == 'ROLE_STAFF' %}
                                        bg-blue-100 text-blue-800
                                    {% else %}
                                        bg-gray-100 text-gray-800
                                    {% endif %}">
                                    {{ log.role|replace({'ROLE_': ''}) }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full
                                    {% if log.action == 'CREATE' %}
                                        bg-green-100 text-green-800
                                    {% elseif log.action == 'UPDATE' %}
                                        bg-yellow-100 text-yellow-800
                                    {% elseif log.action == 'DELETE' %}
                                        bg-red-100 text-red-800
                                    {% elseif log.action == 'LOGIN' %}
                                        bg-blue-100 text-blue-800
                                    {% elseif log.action == 'LOGOUT' %}
                                        bg-gray-100 text-gray-800
                                    {% else %}
                                        bg-purple-100 text-purple-800
                                    {% endif %}">
                                    {{ log.action }}
                                </span>
                            </td>
                            <td class="px-6 py-4 text-sm text-gray-900">{{ log.targetData ?? '-' }}</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">
                                {{ log.timestamp|date('Y-m-d H:i:s') }}
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
                                <a href="{{ path('app_activity_log_show', {id: log.id}) }}" 
                                   class="text-blue-600 hover:text-blue-900">View Details</a>
                            </td>
                        </tr>
                        {% else %}
                        <tr>
                            <td colspan="7" class="px-6 py-4 text-center text-sm text-gray-500">
                                No activity logs found.
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            <div class="mt-4 text-sm text-gray-600">
                <p><strong>Note:</strong> Activity logs are read-only and cannot be modified or deleted.</p>
                <p class="mt-1">Total logs displayed: <strong>{{ logs|length }}</strong></p>
            </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.7/js/dataTables.tailwindcss.min.js"></script>
    <script>
        $(document).ready(function() {
            // Only initialize DataTables if we have data rows (not just the "no data" row)
            if ($('#activityLogsTable tbody tr').length > 0 && !$('#activityLogsTable tbody tr td[colspan]').length) {
                $('#activityLogsTable').DataTable({
                    "order": [[0, "desc"]], // Order by ID descending (newest first)
                    "pageLength": 25,
                    "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
                    "language": {
                        "search": "Search logs:",
                        "lengthMenu": "Show _MENU_ logs per page",
                        "info": "Showing _START_ to _END_ of _TOTAL_ logs",
                        "infoEmpty": "No logs available",
                        "infoFiltered": "(filtered from _MAX_ total logs)",
                        "paginate": {
                            "first": "First",
                            "last": "Last",
                            "next": "Next",
                            "previous": "Previous"
                        }
                    },
                    "columnDefs": [
                        { "orderable": false, "targets": 6 } // Disable sorting on Actions column
                    ],
                    "responsive": true,
                    "dom": '<"flex flex-wrap items-center justify-between mb-4"lf>rt<"flex flex-wrap items-center justify-between mt-4"ip>'
                });
            }
        });
    </script>
{% endblock %}
