{% extends '_layouts/master.html.twig' %}

{% block title %}Activity Log Details{% endblock %}

{% block body %}
<div class="mb-4 flex justify-between items-center">
    <h3 class="text-gray-700 text-2xl font-medium">Activity Log Details</h3>
    <a href="{{ path('app_activity_log') }}" class="px-3 py-2 bg-gray-600 text-white text-sm rounded-md hover:bg-gray-700">
        Back to Logs
    </a>
</div>

            <div class="bg-gray-50 rounded-lg p-4">
                <dl class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div class="border-b border-gray-200 pb-3">
                        <dt class="text-xs font-medium text-gray-500">Log ID</dt>
                        <dd class="mt-1 text-base font-semibold text-gray-900">{{ log.id }}</dd>
                    </div>

                    <div class="border-b border-gray-200 pb-3">
                        <dt class="text-xs font-medium text-gray-500">User ID</dt>
                        <dd class="mt-1 text-base text-gray-900">{{ log.userId }}</dd>
                    </div>

                    <div class="border-b border-gray-200 pb-3">
                        <dt class="text-xs font-medium text-gray-500">Username</dt>
                        <dd class="mt-1 text-base text-gray-900">{{ log.username }}</dd>
                    </div>

                    <div class="border-b border-gray-200 pb-3">
                        <dt class="text-xs font-medium text-gray-500">Role</dt>
                        <dd class="mt-1">
                            <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full
                                {% if log.role == 'ROLE_ADMIN' %}
                                    bg-red-100 text-red-800
                                {% elseif log.role == 'ROLE_STAFF' %}
                                    bg-blue-100 text-blue-800
                                {% else %}
                                    bg-gray-100 text-gray-800
                                {% endif %}">
                                {{ log.role|replace({'ROLE_': ''}) }}
                            </span>
                        </dd>
                    </div>

                    <div class="border-b border-gray-200 pb-3">
                        <dt class="text-xs font-medium text-gray-500">Action Performed</dt>
                        <dd class="mt-1">
                            <span class="px-2 py-1 inline-flex text-xs leading-5 font-semibold rounded-full
                                {% if log.action == 'CREATE' %}
                                    bg-green-100 text-green-800
                                {% elseif log.action == 'UPDATE' %}
                                    bg-yellow-100 text-yellow-800
                                {% elseif log.action == 'DELETE' %}
                                    bg-red-100 text-red-800
                                {% elseif log.action == 'LOGIN' %}
                                    bg-blue-100 text-blue-800
                                {% elseif log.action == 'LOGOUT' %}
                                    bg-gray-100 text-gray-800
                                {% else %}
                                    bg-purple-100 text-purple-800
                                {% endif %}">
                                {{ log.action }}
                            </span>
                        </dd>
                    </div>

                    <div class="border-b border-gray-200 pb-3">
                        <dt class="text-xs font-medium text-gray-500">Date & Time</dt>
                        <dd class="mt-1 text-base text-gray-900">{{ log.timestamp|date('F d, Y g:i:s A') }}</dd>
                    </div>

                    <div class="md:col-span-2">
                        <dt class="text-xs font-medium text-gray-500">Affected Data / Target</dt>
                        <dd class="mt-1 text-base text-gray-900">
                            {% if log.targetData %}
                                {{ log.targetData }}
                            {% else %}
                                <span class="text-gray-400 italic text-sm">No target data recorded</span>
                            {% endif %}
                        </dd>
                    </div>
                </dl>
            </div>

            <div class="mt-4 bg-yellow-50 border border-yellow-200 rounded-lg p-3">
                <div class="flex">
                    <div class="flex-shrink-0">
                        <svg class="h-4 w-4 text-yellow-400" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <div class="ml-2">
                        <h3 class="text-xs font-medium text-yellow-800">Read-Only Record</h3>
                        <p class="mt-1 text-xs text-yellow-700">Activity logs are read-only for security and audit purposes.</p>
        </div>
    </div>
</div>
{% endblock %}